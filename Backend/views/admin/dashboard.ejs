<h2 class="mb-4">Dashboard</h2>

<div class="row g-4 mb-4">

  <div class="col-md-4 col-lg-2">
    <div class="card stat-card p-3 text-center">
      <div class="fs-2 fw-bold text-warning"><%= galleryCount %></div>
      <div class="text-muted small">Gallery</div>
    </div>
  </div>
  
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card stat-card p-4">
      <h5>Quick Actions</h5>
      <div class="d-grid gap-2 mt-3">
        <a href="/admin/hero-sliders" class="btn btn-outline-primary">Manage Hero Sliders</a>
        <a href="/admin/gallery" class="btn btn-outline-primary">Manage Gallery</a>
        <a href="/admin/Notices" class="btn btn-outline-primary">Manage Notices</a>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card stat-card p-4">
      <h5>Content Management</h5>
      <div class="d-grid gap-2 mt-3">
        <a href="/admin/facilities class="btn btn-outline-success">Manage Facilities</a>
        <a href="/admin/activities" class="btn btn-outline-success">Manage Activities</a>
        
      </div>
    </div>
  </div>
</div>
